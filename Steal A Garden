-- Function to get a random rarity based on weighted chance
local function getRandomRarity()
	local totalChance = 0
	for name, rarity in pairs(rarities) do
		totalChance += rarity.Chance
	end

	local randomChance = math.random() * totalChance
	local currentSum = 0

	for name, rarity in pairs(rarities) do
		currentSum += rarity.Chance
		if randomChance <= currentSum then
			return name
		end
	end
end

-- Function to get a random plant mutation based on weighted chance
local function getRandomMutation()
	local totalChance = 0
	for name, rarity in pairs(mutations) do
		totalChance += rarity.Chance
	end

	local randomChance = math.random() * totalChance
	local currentSum = 0

	for name, rarity in pairs(mutations) do
		currentSum += rarity.Chance
		if randomChance <= currentSum then
			return name
		end
	end
end

local function calculateTheTime(object, endObject)
	local difference = (object.Position - endObject.Position).magnitude
	return (difference/SharedSetup.Drone_Speed)
end

-- basic function for formatting number values (mostly currencies)
local function formatNumber(n)
	local suffixes = { "", "k", "M", "B", "T", "Qa", "Qi" }
	local i = 1
	while n >= 1000 and i < #suffixes do
		n = n / 1000
		i = i + 1
	end
	return string.format("%.2f%s", n, suffixes[i])
end


-- Ensure collision group exists
local function ensureCollisionGroup(name)
	local exists = false
	for _, group in ipairs(PhysicsService:GetRegisteredCollisionGroups()) do
		if group.name == name then
			exists = true
			break
		end
	end
	if not exists then
		PhysicsService:RegisterCollisionGroup(name)
	end
end

