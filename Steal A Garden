-- create the player data structure using folders and values inside the player
local function createDataStructure(player, data, parent)
	for name, value in pairs(data) do
		if typeof(value) == "table" and value.Type and value.Value ~= nil and name ~= "Local Data" then -- value
			local val = Instance.new(value.Type)
			val.Name = name
			val.Value = value.Value
			val.Parent = parent
		elseif typeof(value) == "table" and name ~= "Local Data" then -- that's the folder
			local folder = Instance.new("Folder")
			folder.Name = name
			folder.Parent = parent
			createDataStructure(player, value, folder) -- recurrency
		end
	end
end

-- Load player data
function loadData(player, base)
	local success, data = pcall(function()
		return dataStore:GetAsync(player.UserId)
	end)

	createDataStructure(player, PlayerData, player)

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		leaderstats.Parent = player
	end

	if not (success and data) then
		warn("⚠️ No data found or failed to load for", player.Name)

		-- Create default structure manually if needed
		createDataStructure(player, PlayerData, player)

		-- Make sure leaderstats and PlayerData exist
		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats then
			leaderstats.Parent = player
		end

		-- Optionally save default data immediately to DataStore
		local defaultSave = {
			PlayerData = { PlayerData = PlayerData },
			Plants = {},
			QuitTime = os.time(),
		}
		local ok, err = pcall(function()
			dataStore:SetAsync(player.UserId, defaultSave)
		end)
		if not ok then
			warn("❌ Failed to save initial data for new player:", player.Name, err)
		end

		-- Continue setup (don’t return!)
		data = defaultSave
	end


	-- now load the data and put it inside the previously created structure
	local function applyDataStructure(folder, savedData)
		for name, valueData in pairs(savedData) do
			local obj = folder:FindFirstChild(name)
			if obj then
				if obj:IsA("Folder") and typeof(valueData) == "table" then
					applyDataStructure(obj, valueData) -- reccurency
				elseif obj:IsA("ValueBase") then
					if typeof(valueData) == "table" and valueData.Value ~= nil then
						obj.Value = valueData.Value
					elseif typeof(valueData) == typeof(obj.Value) then
						obj.Value = valueData
					end
				end

			end
		end
	end
	
	-- dynamic data structures
	local function applyDynamicDataStructure(folder, savedData)
		for name, valueData in pairs(savedData) do
			local obj = folder:FindFirstChild(name)

			if not obj then
				if typeof(valueData) == "table" and valueData.Type and valueData.Value ~= nil then
					local newVal = Instance.new(valueData.Type, folder)
					newVal.Name = name
					newVal.Value = valueData.Value
					obj = newVal
				elseif typeof(valueData) == "number" then
					local intVal = Instance.new("IntValue", folder)
					intVal.Name = name
					intVal.Value = valueData
					obj = intVal
				end
			end

			if obj then
				if obj:IsA("Folder") and typeof(valueData) == "table" then
					applyDynamicDataStructure(obj, valueData)
				elseif obj:IsA("ValueBase") then
					if typeof(valueData) == "table" and valueData.Value ~= nil then
						obj.Value = valueData.Value
					elseif typeof(valueData) == typeof(obj.Value) then
						obj.Value = valueData
					end
				end
			end
		end
	end

	if data.PlayerData then
		local playerData = player:FindFirstChild("PlayerData")
		local leaderstats = player:FindFirstChild("leaderstats")
		local spinThingy = player:FindFirstChild("PrizeWheel")

		if playerData and data.PlayerData.PlayerData then
			applyDataStructure(playerData, data.PlayerData.PlayerData)

			local dynamicFolders = {"Inventory", "PrizeWheel", "Upgrades"}
			for _, folderName in ipairs(dynamicFolders) do
				local folder = playerData:FindFirstChild(folderName)
				if folder and data.PlayerData.PlayerData[folderName] then
					applyDynamicDataStructure(folder, data.PlayerData.PlayerData[folderName])
				end
			end
		end

		if leaderstats and data.PlayerData.leaderstats then
			applyDataStructure(leaderstats, data.PlayerData.leaderstats)
		end
	end
	
	print(data) -- debug print

	-- handle plants loading and offline income
	if data.Plants and base then
		local timeDifference = os.time() - (data.QuitTime or os.time())
		if timeDifference > SharedSetup.Offline_Income_Max_Time then
			timeDifference = SharedSetup.Offline_Income_Max_Time
		end

		for pot, info in pairs(data.Plants) do
			local currentPot = base.PlantSlots:FindFirstChild(pot)
			if currentPot then
				if info.Plant then
					local setUp = info.Plant
					local stage = setUp.Stage

					local matchingPlant = nil
					for _, plant in ipairs(plants) do
						if plant.Name == setUp.Name then
							matchingPlant = plant
							break
						end
					end

					CropReplacer.CreateNewPot(player, base, setUp, currentPot)

					if matchingPlant then
						local nextStage = scriptStages[stage + 1]
						if nextStage and matchingPlant.Stages[nextStage] then
							local income = matchingPlant.Stages[nextStage].Income
							local multiplier = mutations[info.Plant.Mutation].Multiplier or 1
							
							

							if matchingPlant.Rarity == "Rebirth" then
								local offlineTokens = income * timeDifference * SharedSetup.Offline_Income_Multiplier * multiplier * SharedSetup.Tokens_Boost
								currentPot.OfflineTokens.Value = math.round(offlineTokens * 100) / 100
							else
								multiplier *= 1 + player.leaderstats.Rebirths.Value * SharedSetup.Rebirth_Multiplier
								local offlineMoney = income * timeDifference * SharedSetup.Offline_Income_Multiplier * multiplier * SharedSetup.Money_Boost
								currentPot.OfflineIncome.Value = math.floor(offlineMoney)
							end
						end
					end
				end

				currentPot.MoneyToClaim.Value = info.MoneyToClaim
				currentPot.OfflineIncome.Value += info.OfflineIncome
				currentPot.TokensToClaim.Value = info.TokensToClaim
				currentPot.OfflineTokens.Value += info.OfflineTokens
			end
		end
	end
	
	-- safe inventory setup
	if player:WaitForChild("PlayerData", 5) then
		local pd = player:FindFirstChild("PlayerData")
		local inventory = pd and pd:FindFirstChild("Inventory")
		if inventory then
			if data.PlayerData and data.PlayerData.PlayerData and data.PlayerData.PlayerData.Inventory then
				applyDynamicDataStructure(inventory, data.PlayerData.PlayerData.Inventory)
			end
			print("✅ Firing PlayerLoaded for", player.Name)
			ReplicatedStorage.Remotes.PlayerLoaded:FireClient(player, inventory)
		else
			warn("⚠️ Inventory not found for", player.Name)
		end

	end

	-- free spin handler
	local pd = player:FindFirstChild("PlayerData")
	local prizeWheel = pd and pd:FindFirstChild("PrizeWheel")
	if prizeWheel then
		if prizeWheel:FindFirstChild("LastFreeSpin") and prizeWheel.LastFreeSpin.Value == 0 then
			prizeWheel.LastFreeSpin.Value = os.time()
		end

		local joined = prizeWheel:FindFirstChild("Joined")
		if joined and joined.Value == 0 then
			joined.Value = os.time()
		end
	end

	local loadConn
	loadConn = ReplicatedStorage.Remotes.Load.OnServerEvent:Connect(function(plr)
		if plr == player then
			local localData = player:FindFirstChild("Local Data")
			if localData and localData:FindFirstChild("Loaded") then
				localData.Loaded.Value = true
			end
			if loadConn then
				loadConn:Disconnect()
				loadConn = nil
			end
		end
	end)

	print("✅ About to fire Load for:", player.Name)
	ReplicatedStorage.Remotes.Load:FireClient(player)

	-- manually check for Loaded flag
	local startTime = os.clock()
	local timeout = 10
	repeat
		wait()
	until (player:FindFirstChild("Local Data") and player["Local Data"]:FindFirstChild("Loaded") and player["Local Data"].Loaded.Value == true) or (os.clock() - startTime > timeout)


	print("loaded")
	if not (player:FindFirstChild("Local Data") and player["Local Data"]:FindFirstChild("Loaded") and player["Local Data"].Loaded.Value == true) then
		warn("Player did not confirm client load in time: "..(player.Name or "unknown"))
	end

	-- disconnect load event once confirmed
	if loadConn then
		loadConn:Disconnect()
		loadConn = nil
	end
end


-- Save player data
local function saveData(player)
	if not player then return end

	local data = {
		PlayerData = {},
		Plants = nil,
		QuitTime = os.time(),
		
	}

	local function serializeValues(folder)
		local result = {}

		for _, child in ipairs(folder:GetChildren()) do
			if child:IsA("Folder") then
				result[child.Name] = serializeValues(child)
			elseif child:IsA("ValueBase") then
				result[child.Name] = {
					Value = child.Value,
					Type = child.ClassName
				}
			end
		end

		return result
	end

	local playerDataFolder = player:FindFirstChild("PlayerData")
	local leaderstatsFolder = player:FindFirstChild("leaderstats")

	if playerDataFolder or leaderstatsFolder then
		data.PlayerData = {
			PlayerData = playerDataFolder and serializeValues(playerDataFolder) or {},
			leaderstats = leaderstatsFolder and serializeValues(leaderstatsFolder) or {}
		}
	end

	-- Plants data
	local playersBase
	local plants = {}

	for _, base in pairs(workspace.Map.Plots:GetChildren()) do
		if base:GetAttribute("Owner") == player.UserId then
			playersBase = base
			break
		end
	end

	-- save every info about the plants in the plot
	if playersBase then
		for _, plot in pairs(playersBase.PlantSlots:GetChildren()) do
			local plotInfo = {
				MoneyToClaim = plot.MoneyToClaim.Value, 
				TokensToClaim = plot.TokensToClaim.Value, 
				OfflineIncome = plot.OfflineIncome.Value, 
				OfflineTokens = plot.OfflineTokens.Value, 
				Plant = nil
			}

			if plot:FindFirstChild("Pot") then
				local plant = plot:FindFirstChild("Pot")
				local settings = plant:FindFirstChild("Settings")			

				if settings.Thief.Value == nil then
					plotInfo.Plant = {
						Name = settings.DisplayName.Value, 
						Stage = settings.Stage.Value, 
						StagePercent = settings.StagePercentage.Value, 
						Mutation = settings.Mutation.Value
					}
					plant:Destroy()
				else
					local thief = settings.Thief.Value
					local playersPlot = nil
					local freeSpot

					for _, p in pairs(workspace.Map.Plots:GetChildren()) do
						if p:GetAttribute("Owner") == thief.UserId then
							playersPlot = p
							for _, spot in pairs(p.PlantSlots:GetChildren()) do
								if not spot:FindFirstChild("Pot") and spot:GetAttribute("Occupied") == false then
									freeSpot = spot
									break
								end
							end
							break
						end
					end

					if playersPlot and freeSpot then 
						CropReplacer.CreateNewPot(thief, playersPlot, plant)
					end
				end

				plot.MoneyToClaim.Value = 0
				plot.TokensToClaim.Value = 0
				plot.OfflineIncome.Value = 0
				plot.OfflineTokens.Value = 0
				plot:SetAttribute("Occupied", false)
			end

			plants[plot.Name] = plotInfo
		end

		data.Plants = plants
	end

	local success, err = pcall(function()
		dataStore:SetAsync(player.UserId, data)
	end)
	print(data)

	if not success then
		warn("❌ Failed to save data for", player.Name, ":", err)
	end
end

