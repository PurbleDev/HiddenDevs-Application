					if otherPlayer ~= player and player:IsFriendsWithAsync(otherPlayer.UserId) then
						-- only set collision group if the friend does NOT own a plot
						local isFriendOwner = false
						for _, checkPlot in ipairs(plotsFolder:GetChildren()) do
							if checkPlot:GetAttribute("Owner") == otherPlayer.UserId then
								isFriendOwner = true
								break
							end
						end
						if not isFriendOwner then
							if otherPlayer.Character then
								for _, part in ipairs(otherPlayer.Character:GetDescendants()) do
									if part:IsA("BasePart") then
										part.CollisionGroup = enable and ownerGroup or "Default"
									end
								end
							end
							-- only assign CharacterAdded connection if enabling
							if enable then
								otherPlayer.CharacterAdded:Connect(function(char)
									for _, part in ipairs(char:GetDescendants()) do
										if part:IsA("BasePart") then
											part.CollisionGroup = ownerGroup
										end
									end
								end)
							end
						end
					end
				end
			end

			prompt.Triggered:Connect(function(triggeringPlayer)
				if triggeringPlayer ~= player then return end -- only the owner can use
				friendsAllowed = not friendsAllowed

				for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
					if otherPlayer ~= player and player:IsFriendsWithAsync(otherPlayer.UserId) then
						local friendGroup = "Owner_" .. otherPlayer.UserId
						-- set collision so your walls let their group through if enabled, or block if disabled
						PhysicsService:CollisionGroupSetCollidable(friendGroup, wallGroup, not friendsAllowed)
					end
				end
				if friendsAllowed then
					prompt.ActionText = "Disable Friend Access"
					local imgLabel = friendPanel.Main:FindFirstChild("SurfaceGui") and friendPanel.Main.SurfaceGui:FindFirstChild("ImageLabel")
					if imgLabel then
						imgLabel.Image = "rbxassetid://126413229640303"
					end
				else
					prompt.ActionText = "Enable Friend Access"
					local imgLabel = friendPanel.Main:FindFirstChild("SurfaceGui") and friendPanel.Main.SurfaceGui:FindFirstChild("ImageLabel")
					if imgLabel then
						imgLabel.Image = "rbxassetid://110783679426495"
					end
				end
			end)
		end

		player.CharacterAdded:Connect(function(char)
			for _, part in ipairs(char:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CollisionGroup = ownerGroup
				end
			end
			local spawnObj = plot:FindFirstChild("Spawn")
			if spawnObj and spawnObj:IsA("BasePart") then
				char:MoveTo(spawnObj.Position)
			end
			
			local mult = 1

			if player.PlayerData.Upgrades["Faster Movement"].Value == true then
				mult += SharedSetup.Upgrades["Faster Movement"].Effect
			end

			char.Humanoid.WalkSpeed = SharedSetup.Walk_Speed * mult
			char.Humanoid.JumpHeight = SharedSetup.Jump_Height
			
			player.PlayerData.Upgrades["Faster Movement"].Changed:Connect(function()
				local mult2 = 1

				if player.PlayerData.Upgrades["Faster Movement"].Value == true then
					mult2 += SharedSetup.Upgrades["Faster Movement"].Effect
				end

				char.Humanoid.WalkSpeed = SharedSetup.Walk_Speed * mult2
				char.Humanoid.JumpHeight = SharedSetup.Jump_Height
			end)
		end)

		task.defer(function()
			TimeForSpin(player)
			print("executed")
		end)


		player.PlayerData.Upgrades["Quicker Spins"].Changed:Connect(function()
			print("changed, fired")
			TimeForSpin(player)
		end)

		player:LoadCharacterAsync()
	else
		warn("No unowned plots available for " .. player.Name)
		player:Kick("Error: No unowned plots available for you. Please try again!")
	end
end)

