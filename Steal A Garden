local ClaimFreeSpin = ReplicatedStorage.Remotes:WaitForChild("ClaimFreeSpin")

local COOLDOWN_TIME = 5

local spinCooldown = {}

-- rewards
local basePrizes = SharedSetup.Prize_Wheel_Prizes

-- generate random prize for the player
local function getPrizesForPlayer(player)
	local prizes = table.clone(basePrizes)

	local prizeWheel = player:FindFirstChild("PlayerData") and player.PlayerData:FindFirstChild("PrizeWheel")
	if not prizeWheel then return prizes end

	for _, prize in ipairs(prizes) do
		if prize.Type == "Legendary" then
			if os.time() - SharedSetup.Legendary_Luck_Boost_Time <= prizeWheel:FindFirstChild("Joined").Value then
				prize.Chance = basePrizes[8].Chance * SharedSetup.Legendary_Luck_Boost_Multiplier
			else
				prize.Chance = basePrizes[8].Chance
			end

		end
	end
	
	return prizes
end


-- random prize generator 3000
local function getRandomPrize(prizes)
	local totalWeight = 0
	for _, prize in ipairs(prizes) do
		totalWeight += prize.Chance
	end

	local roll, cumulative = math.random(totalWeight), 0
	for _, prize in ipairs(prizes) do
		cumulative += prize.Chance
		if roll <= cumulative then
			return prize
		end
	end
end

-- get a random angle
local function getPrizeAngle(prize)
	local min, max = table.unpack(prize.Range)
	if min > max then min, max = max, min end
	return math.random(min, max)
end

-- wheel spinning
PrizeWheelSpin.OnServerEvent:Connect(function(player)
	local now = os.clock()
	if spinCooldown[player] and now - spinCooldown[player] < COOLDOWN_TIME then
		return
	end
	spinCooldown[player] = now

	local prizeWheel = player:FindFirstChild("PlayerData") and player.PlayerData:FindFirstChild("PrizeWheel")
	if not prizeWheel then return end

	-- check if player has any spins left
	local spins = prizeWheel:FindFirstChild("Spins")
	if not spins or spins.Value <= 0 then return end

	spins.Value -= 1

	local prizes = getPrizesForPlayer(player)
	local prize = getRandomPrize(prizes)
	local finalAngle = getPrizeAngle(prize)

	local totalRotation = (360 * math.random(3, 6)) + finalAngle

	PrizeWheelSpin:FireClient(player, prize, totalRotation)

	task.delay(4, function()
		if not player.Parent then return end 
		
		-- REWARDS
		if prize.Type == "Coins" then
			print("adding coins")
			player.leaderstats.Coins.Value += prize.Amount
		elseif prize.Type == "Tokens" then
			player.PlayerData.Tokens.Value += prize.Amount
		elseif prize.Type == "Rare" or prize.Type == "Epic" or prize.Type == "Legendary" then
			local playersBase = findPlayerBase(player)

			if playersBase then
				local data = {
					Mutation = CropReplacer.getRandomMutation(),
					Name = CropReplacer.selectPlantByRarity(prize.Type).Name,
					Stage = 0,
					StagePercent = 0
				}

				CropReplacer.CreateNewPot(player, playersBase, data)
			end
		end
	end)
end)

