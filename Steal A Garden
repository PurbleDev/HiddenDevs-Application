local function numberToTime(n)
	local hours = math.floor(n / 3600)
	local minutes = math.floor((n % 3600) / 60)
	local seconds = n % 60
	return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

-- Processes one spawn from the queue every 2 seconds
task.spawn(function()
	while true do
		wait(SharedSetup.Drone_Spawn_Time)

		local chosen = getRandomRarity()
		local selectedPlant = CropReplacer.selectPlantByRarity(chosen)
		local mutation = getRandomMutation()

		SpawnQueue.Add({
			plant = selectedPlant,
			rarity = chosen,
			mutation = mutation,
			stage = 0
		})

		if SpawnQueue.Size() > 0 then
			local cropData = SpawnQueue.Pop()

			local selectedPlant = cropData.plant
			local stage = cropData.stage
			local mutation = cropData.mutation
			local chosen = cropData.rarity

			local cropModel = ReplicatedStorage.Crops:FindFirstChild(selectedPlant.Name)
			if not cropModel then
				warn("Cannot find model for:", selectedPlant.Name, "- falling back to PlaceholderCrop.")
				cropModel = ReplicatedStorage.Crops:FindFirstChild("PlaceholderCrop")
			end

			if cropModel then
				local clone = game.ReplicatedStorage.Instances.Drone:Clone()
				local primary = clone.PrimaryPart
				clone.Parent = workspace
				clone:MoveTo(workspace.Map.Road.Start.Position)

				CropReplacer.SpawnCropNew(clone:FindFirstChildOfClass("Model"), selectedPlant.Name, stage, mutation)

				local cost = clone.Settings.Cost
				local occupied = clone.Settings.Occupied
				local originalCost = clone.Settings.OriginalCost
				local rarity = clone.Settings.Rarity
				local income = clone.Settings.Income
				local mutationValue = clone.Settings.Mutation
				local displayName = clone.Settings.DisplayName

				local billboard = clone:FindFirstChildOfClass("Model").PrimaryPart.Attachment:FindFirstChild("AnimalOverhead")

				cost.Changed:Connect(function()
					billboard.Price.Text = "$" .. formatNumber(cost.Value)
				end)

				originalCost.Value = selectedPlant.Price
				cost.Value = selectedPlant.Price
				income.Value = 1
				rarity.Value = chosen
				displayName.Value = selectedPlant.Name
				mutationValue.Value = mutation
				
				local data = {
					Mutation = mutation,
					Name = selectedPlant.Name,
					Stage = stage,
					StagePercent = clone.Settings.StagePercentage.Value
				}

				if mutationValue.Value == "None" then
					billboard.Mutation.Visible = false
				else
					billboard.Mutation.Visible = true
					if ReplicatedStorage.MutationsGradients:FindFirstChild(mutationValue.Value) then
						ReplicatedStorage.MutationsGradients:FindFirstChild(mutationValue.Value):Clone().Parent = billboard.Mutation
					end
				end

				if gradients:FindFirstChild(chosen) then
					gradients:FindFirstChild(chosen):Clone().Parent = billboard.Rarity
				end

				billboard.DisplayName.Text = selectedPlant.Name
				billboard.Rarity.Text = selectedPlant.Rarity

				local nmb2Stage = stagesModule.Utils.NumberToStage(stage)
				local nmb2FancyStage = stagesModule.Utils.NumberToStage(stage, true)
				local baseIncome = selectedPlant.Stages[nmb2Stage].Income or stage
				income.Value = baseIncome
				billboard.Generation.Text = "$" .. formatNumber(income.Value * mutations[mutation].Multiplier) .. "/s"

				billboard.Stage.Text = nmb2FancyStage


				local time = calculateTheTime(primary, workspace.Map.Road.End)

				local currentTween -- to store current tween
				local tweenConnection -- to disconnect tween event if needed

				-- Start tween to the end of the conveyor
				currentTween = tS:Create(primary, TweenInfo.new(time, Enum.EasingStyle.Linear), {
					CFrame = workspace.Map.Road.End.CFrame
				})
				currentTween:Play()

				-- Handle tween complete: remove drone if unclaimed
				tweenConnection = currentTween.Completed:Connect(function(playbackState)
					if playbackState == Enum.PlaybackState.Completed then
						if not clone.Settings.Occupied.Value then
							clone:Destroy()
						end
					end
				end)

				-- Handle player claiming or re-claiming the drone
				primary.ProximityPrompt.Triggered:Connect(function(player)
					local leaderstats = player:FindFirstChild("leaderstats")
					if not leaderstats then return end

					local coins = leaderstats:FindFirstChild("Coins")
					if not coins then return end
					
					if player["Local Data"].Loaded == false then return end

					local freeSpot = nil
					local playersPlot = nil

					local previousSpot = nil
					for _, plot in pairs(workspace.Map.Plots:GetChildren()) do
						if plot:GetAttribute("Owner") == player.UserId then
							playersPlot = plot
							freeSpot = locateEmptySlot(playersPlot)
							break
						end
					end
					if not playersPlot or not freeSpot then return end

					local currentOwner = occupied.Value

					-- Buying from no one
					if not currentOwner then
						if coins.Value < cost.Value then
							return
						end

						coins.Value -= cost.Value
						occupied.Value = player

						cost.Value = math.ceil(cost.Value * 1.1)

						if currentTween then currentTween:Cancel() end
						if tweenConnection then tweenConnection:Disconnect() end

						local timeToPlot = calculateTheTime(primary, playersPlot.DeliveryHitbox)
						currentTween = tS:Create(primary, TweenInfo.new(timeToPlot, Enum.EasingStyle.Linear), {
							CFrame = playersPlot.DeliveryHitbox.CFrame
						})
						currentTween:Play()
						freeSpot:SetAttribute("Occupied", true)
						reservedSpots[clone] = {
							player = player,
							slot = freeSpot
						}


						for t, p in pairs(game:GetService("Players"):GetChildren()) do
							if p == player then
								game.ReplicatedStorage.Remotes.DroneProx:FireClient(p, clone, false)
							else
								game.ReplicatedStorage.Remotes.DroneProx:FireClient(p, clone, true)
							end
						end


						tweenConnection = currentTween.Completed:Connect(function(playbackState)
							if playbackState == Enum.PlaybackState.Completed then
								CropReplacer.CreateNewPot(player, playersPlot, data, freeSpot)
								reservedSpots[clone] = nil
								clone:Destroy()
							end
						end)

					else
						-- Prevent rebuying from self
						if currentOwner == player then
							return
						end

						-- Rebuying logic


						if coins.Value < cost.Value then
							return
						end

						coins.Value -= cost.Value
						occupied.Value = player

						cost.Value = math.ceil(cost.Value * 1.1)

						if currentTween then currentTween:Cancel() end
						if tweenConnection then tweenConnection:Disconnect() end

						local timeToPlot = calculateTheTime(primary, playersPlot.DeliveryHitbox)
						currentTween = tS:Create(primary, TweenInfo.new(timeToPlot, Enum.EasingStyle.Linear), {
							CFrame = playersPlot.DeliveryHitbox.CFrame
						})
						currentTween:Play()
						freeSpot:SetAttribute("Occupied", true)

						local reserved = reservedSpots[clone]
						if reserved and reserved.player ~= player then
							reserved.slot:SetAttribute("Occupied", false)
						end

						freeSpot:SetAttribute("Occupied", true)
						reservedSpots[clone] = {
							player = player,
							slot = freeSpot
						}

						for t, p in pairs(game:GetService("Players"):GetChildren()) do
							if p == player then
								game.ReplicatedStorage.Remotes.DroneProx:FireClient(p, clone, false)
							else
								game.ReplicatedStorage.Remotes.DroneProx:FireClient(p, clone, true)
							end
						end

						tweenConnection = currentTween.Completed:Connect(function(playbackState)
							if playbackState == Enum.PlaybackState.Completed then
								CropReplacer.CreateNewPot(player, playersPlot, data, freeSpot)
								reservedSpots[clone] = nil
								clone:Destroy()
							end
						end)
					end
				end)
			end
		end
	end
end)


