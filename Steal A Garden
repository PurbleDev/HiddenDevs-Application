local function findPlayerBase(player)
	local playerPlot = nil
	for _, plot in pairs(plotsFolder:GetChildren()) do
		if plot:GetAttribute("Owner") == player.UserId then
			playerPlot = plot
			break
		end
	end
	return playerPlot
end
local function resetBase(player)
	local playerPlot = findPlayerBase(player)
	
	if playerPlot then
		for _, slot in pairs(playerPlot.PlantSlots:GetChildren()) do
			slot.MoneyToClaim.Value = 0
			slot.OfflineIncome.Value = 0
			if slot:FindFirstChild("Pot") then
				slot.Pot:Destroy()
			end
		end
	end
end
local function calculateCost(player)
	local leaderstats = player:WaitForChild("leaderstats")
	local rebirths = leaderstats:WaitForChild("Rebirths")

	local startcost = 10000000

	return startcost + startcost*(rebirths.Value+1)/5
end

local function findARebirthPlant(plot)
	local rebirthPlant = nil
	for _, slot in pairs(plot.PlantSlots:GetChildren()) do
		if slot:FindFirstChild("Pot") then
			if slot:FindFirstChild("Pot"):WaitForChild("Settings"):WaitForChild("Rarity").Value == "Rebirth" and slot:FindFirstChild("Pot"):WaitForChild("Settings"):WaitForChild("Stage").Value == 5 then
				rebirthPlant = slot
				return rebirthPlant
			end
		end
	end
	return rebirthPlant
end

-- rebirth if player fills the requirements
ReplicatedStorage.Remotes.Rebirth.OnServerEvent:Connect(function (player)
	if player then
		local leaderstats = player:WaitForChild("leaderstats")
		local rebirths = leaderstats:WaitForChild("Rebirths")
		local coins = leaderstats:WaitForChild("Coins")
		
		local cost = tonumber(calculateCost(player))
		
		local playerPlot = findPlayerBase(player)

		if playerPlot then
			local rebirthPlant = findARebirthPlant(playerPlot)
			
			if coins.Value >= cost and rebirthPlant then
				resetBase(player)
				rebirths.Value += 1
				coins.Value = 2500
			end
		end
	end
end)

