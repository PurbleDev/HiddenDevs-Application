function TimeForSpin(player)
	if not player then return end
	if not player:FindFirstChild("PlayerData") then return end
	local prizeWheel = player.PlayerData:FindFirstChild("PrizeWheel")
	if not prizeWheel then return end

	local lastSpin = prizeWheel:FindFirstChild("LastFreeSpin")
	local spins = prizeWheel:FindFirstChild("Spins")
	if not lastSpin or not spins then return end

	if not player.PlayerData:FindFirstChild("Upgrades") or not player.PlayerData.Upgrades:FindFirstChild("Quicker Spins") then
		return
	end

	local now = os.time()
	local hasTo = FREE_SPIN_COOLDOWN

	if player.PlayerData.Upgrades["Quicker Spins"].Value == true then
		hasTo = hasTo * (1 - SharedSetup.Upgrades["Quicker Spins"].Effect)
	end

	if now - lastSpin.Value >= hasTo then
		spins.Value += 1
		lastSpin.Value = now

	end
	
	FreeSpinData:FireClient(player, lastSpin.Value, hasTo)
end

