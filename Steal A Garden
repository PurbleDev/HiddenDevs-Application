local function toggleLasers(plot, value)
	local laserHitbox = plot:FindFirstChild("LaserHitbox")
	if laserHitbox and laserHitbox:FindFirstChild("Main") then
		laserHitbox.Main.CanCollide = value
	end

	local lasers = plot:FindFirstChild("Laser")
	if lasers then
		for _, model in ipairs(lasers:GetChildren()) do
			for _, part in ipairs(model:GetChildren()) do
				if part.Name == "laserBase" then
					part.Transparency = value and 0 or 1
				elseif part.Name == "laserPart" then
					part.Transparency = value and 0.6 or 1
				end
			end
		end
	end
end

